{
	"name": "ripple-click",
	"version": "1.0.0",
	"description": "A polished Windows tray app that makes clicks easy to follow during demos, reviews, training, and screen sharing.",
	"main": "src/main.js",
	"scripts": {
		"start": "electron .",
		"dev": "node scripts/dev-watch.js",
		"dev:once": "electron .",
		"package:win": "electron-builder --win portable"
	},
	"keywords": [
		"windows",
		"screen-sharing",
		"click-highlight",
		"electron"
	],
	"author": "",
	"license": "MIT",
	"devDependencies": {
		"electron": "^31.7.7",
		"electron-builder": "^24.13.3"
	},
	"build": {
		"appId": "com.rippleclick.app",
		"productName": "RippleClick",
		"files": [
			"build/icon.ico",
			"src/**/*",
			"package.json"
		],
		"win": {
			"icon": "build/icon.ico",
			"signAndEditExecutable": false,
			"target": [
				"portable"
			]
		}
	}
}
